              </Attribute>
              <Attribute Name="value_mapping" AttributeDataType="xs:string">
                <Value>1</Value>
                <Constraint Name="traffic_light_2_weight_contraint">
                  <NominalScaledType>
                    <RequiredValue>0</RequiredValue>
                    <RequiredValue>0.4</RequiredValue>
                    <RequiredValue>0.7</RequiredValue>
                    <RequiredValue>1</RequiredValue>
                  </NominalScaledType>
                </Constraint>
              </Attribute>
              <Attribute Name="result" AttributeDataType="xs:string">
                <Value>1</Value>
              </Attribute>
              <Attribute Name="intent_semantics"
                RefAttributeType="IRS_IntentSemantics_Attribute_Library/intent_semantics" />
            </Attribute>
