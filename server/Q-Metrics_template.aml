          <InternalElement Name="Robustness" ID="b9b7d5ec-a537-4cce-bae6-8283b144e4df"
            RefBaseSystemUnitPath="Simulation_Quality_Metric/Attribute">
            <Description>Does the model remain stable with discontinous inputs ?
              Does the model remain stable with frequent state changes (toggling, chattering) ?
              Does the model remain stable when a certain range of values is exceeded (e.g. integer
              overflow) ?
              Does the model remain stable when extreme or boundery values occur ?

              Further examples of robustness tests:
              1. Sending a CAN message with an invalid payload
              2. Transferring a zero pointer
              3. Division by zero
              4. etc.


              red: The model is not robust
              orange: The model is conditionally robust
              yellow: The model is mostly robust
              green: The model is very robust</Description>
            <Attribute Name="Traffic_Light_2" AttributeDataType="xs:string"
              RefAttributeType="Simulation_Quality_Metric_Attribute_Libary/Traffic_Light_2">
              <Attribute Name="value" AttributeDataType="xs:string">
                <Constraint Name="traffic_light_2_value_constraint">
                  <NominalScaledType>
                    <RequiredValue>red</RequiredValue>
                    <RequiredValue>orange</RequiredValue>
                    <RequiredValue>yellow</RequiredValue>
                    <RequiredValue>green</RequiredValue>
                  </NominalScaledType>
                </Constraint>
              </Attribute>
              <Attribute Name="value_mapping" AttributeDataType="xs:string">
                <Constraint Name="traffic_light_2_weight_contraint">
                  <NominalScaledType>
                    <RequiredValue>0</RequiredValue>
                    <RequiredValue>0.4</RequiredValue>
                    <RequiredValue>0.7</RequiredValue>
                    <RequiredValue>1</RequiredValue>
                  </NominalScaledType>
                </Constraint>
              </Attribute>
              <Attribute Name="result" AttributeDataType="xs:string" />
              <Attribute Name="intent_semantics"
                RefAttributeType="IRS_IntentSemantics_Attribute_Library/intent_semantics" />
            </Attribute>
            <Attribute Name="Percentage_Weighting" AttributeDataType="xs:string"
              RefAttributeType="Simulation_Quality_Metric_Attribute_Libary/Percentage_Weighting"
              editor_id="default">
              <Attribute Name="weight" AttributeDataType="xs:string">
                <Value>0.2</Value>
                <Constraint Name="percentage_weight_constraint">
                  <OrdinalScaledType>
                    <RequiredMaxValue>1.0</RequiredMaxValue>
                    <RequiredMinValue>0.0</RequiredMinValue>
                  </OrdinalScaledType>
                </Constraint>
              </Attribute>
              <Attribute Name="result" AttributeDataType="xs:string">
                <Value>0.2</Value>
              </Attribute>
              <Attribute Name="intent_semantics"
                RefAttributeType="IRS_IntentSemantics_Attribute_Library/intent_semantics" />
            </Attribute>
          </InternalElement>
          <InternalElement Name="Runtime" ID="0e6d2ff4-9639-4287-abed-eb136e72b9c9"
            RefBaseSystemUnitPath="Simulation_Quality_Metric/Attribute">
            <Description>This is a distinguishing feature, it does not influence
              the result with regard to the quality statement.

              Is the model real-time capable?</Description>
            <Attribute Name="Real_time_capability" AttributeDataType="xs:string"
              RefAttributeType="Simulation_Quality_Metric_Attribute_Libary/Real_time_capability">
              <Attribute Name="value" AttributeDataType="xs:string">
                <Constraint Name="real-time_value_constraint">
                  <NominalScaledType>
                    <RequiredValue>not real-time- capable</RequiredValue>
                    <RequiredValue>soft real-time</RequiredValue>
                    <RequiredValue>hard real-time</RequiredValue>
                  </NominalScaledType>
                </Constraint>
              </Attribute>
              <Attribute Name="value_mapping" AttributeDataType="xs:string">
                <Constraint Name="real-time_weight_contraint">
                  <NominalScaledType>
                    <RequiredValue>0</RequiredValue>
                    <RequiredValue>0.5</RequiredValue>
                    <RequiredValue>1.0</RequiredValue>
                  </NominalScaledType>
                </Constraint>
              </Attribute>
              <Attribute Name="result" AttributeDataType="xs:string" />
              <Attribute Name="intent_semantics"
                RefAttributeType="IRS_IntentSemantics_Attribute_Library/intent_semantics" />
            </Attribute>
            <Attribute Name="Percentage_Weighting" AttributeDataType="xs:string"
